NODE_ENV=development
PORT=3333

# PostgreSQL usado pelo Prisma.
# Local exemplo:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/automedia?schema=public"

# Redis/fila BullMQ.
# Local: redis://localhost:6379
# Upstash/producao: prefira rediss://default:SENHA@HOST:PORT
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Use um segredo forte em producao.
JWT_SECRET="change-me-in-production"
ENCRYPTION_KEY="change-me-32-characters-minimum"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"
LOGIN_FAILURE_LIMIT="5"
LOGIN_LOCK_MINUTES="15"
LOGIN_WINDOW_MINUTES="15"
WEBHOOK_SECRET=""

# Frontends autorizados a chamar a API.
CORS_ORIGIN="https://auto-media-sooty.vercel.app,http://localhost:5173,http://localhost:4173"
FRONTEND_URL="https://auto-media-sooty.vercel.app"
API_PUBLIC_URL="https://auto-media-backend.vercel.app"

# mock mantém a plataforma testável sem credenciais.
# live usa OAuth real e exige as credenciais abaixo no provedor correspondente.
SOCIAL_INTEGRATIONS_MODE="mock"

# Meta: Instagram/Facebook Graph API
META_CLIENT_ID=""
META_CLIENT_SECRET=""
META_REDIRECT_URI="https://auto-media-backend.vercel.app/api/platform-callback?platform=instagram"
META_GRAPH_VERSION="v21.0"

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="https://auto-media-backend.vercel.app/api/platform-callback?platform=tiktok"

# YouTube Data API
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="https://auto-media-backend.vercel.app/api/platform-callback?platform=youtube"

# Mercado Livre
MERCADOLIVRE_CLIENT_ID=""
MERCADOLIVRE_CLIENT_SECRET=""
MERCADOLIVRE_REDIRECT_URI="https://auto-media-backend.vercel.app/api/platform-callback?platform=mercadolivre"

# Shopee
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
SHOPEE_REDIRECT_URI="https://auto-media-backend.vercel.app/api/platform-callback?platform=shopee"
SHOPEE_API_BASE_URL="https://partner.shopeemobile.com"

# OpenAI Images API para criativos visuais na tela de geracao de videos.
# Em produção, configure a chave real. O fallback local fica desligado por padrão.
OPENAI_API_KEY=""
OPENAI_TEXT_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_QUALITY="high"
OPENAI_IMAGE_FALLBACK_ENABLED="false"

# Video IA externo.
# ffmpeg = render local seguro. replicate_kling = geração IA real via Replicate/Kling.
# Para Replicate/Kling funcionar, a imagem inicial do produto precisa estar em URL pública.
AI_VIDEO_PROVIDER="ffmpeg"
AI_VIDEO_FALLBACK_TO_FFMPEG="true"
REPLICATE_API_TOKEN=""
REPLICATE_KLING_MODEL="kwaivgi/kling-v2.1"
REPLICATE_KLING_MODE="standard"
REPLICATE_KLING_NEGATIVE_PROMPT="low quality, distorted product, unreadable text, extra fingers, deformed hands, watermark, logo distortion"
REPLICATE_POLL_INTERVAL_MS="5000"
REPLICATE_TIMEOUT_MS="420000"

# local salva em /uploads. s3 usa MinIO/AWS S3. supabase salva no bucket configurado abaixo.
STORAGE_DRIVER="local"
UPLOADS_DIR="uploads"
BACKUPS_DIR="backups"
BACKUP_RETENTION_DAYS="14"
MINIO_DATA_DIR="../data/minio"

# S3/MinIO
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_URL="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="automedia-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="videos"

# Renderizacao real de videos.
# Em producao, rode o worker: npm run worker:video
# FFmpeg precisa estar instalado no ambiente do worker.
VIDEO_RENDER_DRIVER="ffmpeg"
FFMPEG_PATH="ffmpeg"
