# AutoMedia Backend - exemplo para VM/Home Lab
# Copie para .env.local na VM e troque TODOS os valores marcados como TROCAR.
# Este arquivo nao deve conter chaves reais.

NODE_ENV=production
PORT=3333

# Infra local da VM em Docker
DATABASE_URL="postgresql://automedia:TROCAR_SENHA_POSTGRES@localhost:5432/automedia?schema=public"
REDIS_URL="redis://localhost:6379"

# Seguranca
JWT_SECRET="TROCAR_GERE_UM_SEGREDO_FORTE_COM_32_OU_MAIS_CARACTERES"
ENCRYPTION_KEY="TROCAR_GERE_UMA_CHAVE_FORTE_COM_32_OU_MAIS_CARACTERES"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"
LOGIN_FAILURE_LIMIT="5"
LOGIN_LOCK_MINUTES="15"
LOGIN_WINDOW_MINUTES="15"
WEBHOOK_SECRET="TROCAR_SE_FOR_USAR_WEBHOOKS"

# Frontend autorizado
CORS_ORIGIN="http://localhost:5173,http://localhost:4173,https://auto-media-sooty.vercel.app"
FRONTEND_URL="https://auto-media-sooty.vercel.app"
API_PUBLIC_URL="http://192.168.1.6:3333"

# IA de texto/imagem
OPENAI_API_KEY="TROCAR_OPENAI_API_KEY"
OPENAI_ADMIN_API_KEY=""
OPENAI_TEXT_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_QUALITY="high"
OPENAI_IMAGE_FALLBACK_ENABLED="false"

# Video IA
AI_VIDEO_PROVIDER="replicate_kling"
AI_VIDEO_FALLBACK_TO_FFMPEG="true"
AI_VIDEO_SEGMENT_ESTIMATED_COST_USD="0.08"
AI_VIDEO_FFMPEG_ESTIMATED_COST_USD="0"
REPLICATE_API_TOKEN="TROCAR_REPLICATE_API_TOKEN"
REPLICATE_KLING_MODEL="kwaivgi/kling-v2.1"
REPLICATE_KLING_MODE="standard"
REPLICATE_KLING_NEGATIVE_PROMPT="low quality, distorted product, unreadable text, extra fingers, deformed hands, watermark, logo distortion"
REPLICATE_POLL_INTERVAL_MS="5000"
REPLICATE_TIMEOUT_MS="420000"

# Storage persistente na VM via MinIO/S3
STORAGE_DRIVER="s3"
UPLOADS_DIR="uploads"
BACKUPS_DIR="backups"
BACKUP_RETENTION_DAYS="14"
MINIO_DATA_DIR="../data/minio"
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_URL="http://192.168.1.6:9000"
S3_REGION="us-east-1"
S3_BUCKET="automedia-media"
S3_ACCESS_KEY_ID="TROCAR_MINIO_ACCESS_KEY"
S3_SECRET_ACCESS_KEY="TROCAR_MINIO_SECRET_KEY"
S3_FORCE_PATH_STYLE="true"

# Supabase opcional futuro
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="videos"

# Render local/fallback
VIDEO_RENDER_DRIVER="ffmpeg"
FFMPEG_PATH="ffmpeg"

# Integracoes sociais
SOCIAL_INTEGRATIONS_MODE="mock"
META_CLIENT_ID=""
META_CLIENT_SECRET=""
META_REDIRECT_URI="http://192.168.1.6:3333/api/platform-callback?platform=instagram"
META_GRAPH_VERSION="v21.0"
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://192.168.1.6:3333/api/platform-callback?platform=tiktok"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://192.168.1.6:3333/api/platform-callback?platform=youtube"
MERCADOLIVRE_CLIENT_ID=""
MERCADOLIVRE_CLIENT_SECRET=""
MERCADOLIVRE_REDIRECT_URI="http://192.168.1.6:3333/api/platform-callback?platform=mercadolivre"
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
SHOPEE_REDIRECT_URI="http://192.168.1.6:3333/api/platform-callback?platform=shopee"
SHOPEE_API_BASE_URL="https://partner.shopeemobile.com"
