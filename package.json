{
  "name": "automedia-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:push:safe": "node scripts/safe-db-push.mjs",
    "db:verify:security": "node scripts/verify-database-security.mjs",
    "db:backfill:security": "node scripts/backfill-security-workspace.mjs",
    "db:backup": "node scripts/backup-database.mjs",
    "crud:check": "node scripts/verify-crud-contract.mjs",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "build": "prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.json",
    "build:vercel": "npm run build",
    "start": "node dist/src/server.js",
    "worker:video": "tsx src/modules/videos/video-generation.worker.cli.ts",
    "prod:check": "node scripts/check-production-env.mjs",
    "infra:check": "node scripts/check-infrastructure.mjs",
    "secrets:rotate:checklist": "node scripts/rotate-secrets-checklist.mjs",
    "check:errors": "node scripts/report-errors-only.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.56.4",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.7.0",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.18",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
