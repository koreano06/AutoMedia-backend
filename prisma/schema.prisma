generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String   @map("password_hash")
  storeName    String?  @map("store_name")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  approvals Approval[]

  @@map("users")
}

model Product {
  id                   String   @id @default(cuid())
  name                 String
  inputSource          String?  @map("input_source")
  sourceUrl            String?  @map("source_url")
  imageUrl             String?  @map("image_url")
  uploadedImageUrl     String?  @map("uploaded_image_url")
  category             String?
  description          String?
  brand                String?
  price                Decimal? @db.Decimal(12, 2)
  costPrice            Decimal? @map("cost_price") @db.Decimal(12, 2)
  marginPercent        Float?   @map("margin_percent")
  sku                  String?
  internalCode         String?  @map("internal_code")
  supplierName         String?  @map("supplier_name")
  supplierContact      String?  @map("supplier_contact")
  supplierLeadTimeDays Int?     @map("supplier_lead_time_days")
  stockQuantity        Int?     @default(0) @map("stock_quantity")
  minStock             Int?     @default(0) @map("min_stock")
  marketplaceOrigin    String?  @map("marketplace_origin")
  currency             String?  @default("BRL")
  productUrl           String?  @map("product_url")
  affiliateUrl         String?  @map("affiliate_url")
  keywords             String[] @default([])
  attributes           Json?
  analysisSummary      String?  @map("analysis_summary")
  status               String   @default("draft")
  mediaCount           Int      @default(0) @map("media_count")
  postsPublished       Int      @default(0) @map("posts_published")
  videosGenerated      Int      @default(0) @map("videos_generated")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  analyses ProductAnalysis[]
  media    MediaAsset[]
  posts    Post[]
  marketplaceListings MarketplaceListing[]
  salesOrderItems SalesOrderItem[]

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("products")
}

model ProductAnalysis {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  provider    String?
  inputType   String?  @map("input_type")
  confidence  Float?
  summary     String?
  rawResponse Json?    @map("raw_response")
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_analyses")
}

model MediaAsset {
  id              String   @id @default(cuid())
  productId       String?  @map("product_id")
  productName     String?  @map("product_name")
  type            String   @default("image")
  title           String?
  status          String   @default("collected")
  source          String?
  sourceUrl       String?  @map("source_url")
  url             String?
  thumbnailUrl    String?  @map("thumbnail_url")
  storageKey      String?  @map("storage_key")
  mimeType        String?  @map("mime_type")
  fileSize        Int?     @map("file_size")
  caption         String?
  platforms       String[] @default([])
  qualityScore    Float?   @map("quality_score")
  duration        String?
  reviewNotes     String?  @map("review_notes")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?  @map("reviewed_by")
  previousStatus  String?  @map("previous_status")
  rejectionReason String?  @map("rejection_reason")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  approvals   Approval[]
  collections MediaCollectionSource[]
  posts       Post[]

  @@index([productId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("media_assets")
}

model MediaCollectionSource {
  id           String   @id @default(cuid())
  mediaAssetId String   @map("media_asset_id")
  sourceType   String   @map("source_type")
  sourceUrl    String?  @map("source_url")
  provider     String?
  status       String   @default("collected")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId])
  @@index([sourceType])
  @@map("media_collection_sources")
}

model Approval {
  id              String   @id @default(cuid())
  mediaAssetId    String   @map("media_asset_id")
  reviewerId      String?  @map("reviewer_id")
  previousStatus  String?  @map("previous_status")
  status          String
  notes           String?
  rejectionReason String?  @map("rejection_reason")
  platforms       String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at")

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  reviewer   User?      @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([mediaAssetId])
  @@index([status])
  @@map("approvals")
}

model Post {
  id                 String   @id @default(cuid())
  productId          String?  @map("product_id")
  mediaAssetId       String?  @map("media_asset_id")
  productName        String?  @map("product_name")
  platform           String?
  caption            String?
  status             String   @default("scheduled")
  scheduledAt        DateTime? @map("scheduled_at")
  publishedAt        DateTime? @map("published_at")
  externalPostId     String?  @map("external_post_id")
  externalUrl        String?  @map("external_url")
  errorMessage       String?  @map("error_message")
  engagementLikes    Int      @default(0) @map("engagement_likes")
  engagementComments Int      @default(0) @map("engagement_comments")
  engagementShares   Int      @default(0) @map("engagement_shares")
  engagementReach    Int      @default(0) @map("engagement_reach")
  thumbnailUrl       String?  @map("thumbnail_url")
  campaignName       String?  @map("campaign_name")
  retryCount         Int      @default(0) @map("retry_count")
  lastSyncAt         DateTime? @map("last_sync_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  product    Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  mediaAsset MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  comments   Comment[]
  metrics    PostMetric[]

  @@index([productId])
  @@index([mediaAssetId])
  @@index([platform])
  @@index([status])
  @@index([scheduledAt])
  @@index([publishedAt])
  @@map("posts")
}

model PostMetric {
  id              String   @id @default(cuid())
  postId          String   @map("post_id")
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  reach           Int      @default(0)
  engagementRate  Float?   @map("engagement_rate")
  capturedAt      DateTime @default(now()) @map("captured_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([capturedAt])
  @@map("post_metrics")
}

model MarketplaceListing {
  id                String    @id @default(cuid())
  productId         String    @map("product_id")
  platform          String
  title             String
  description       String?
  price             Decimal?  @db.Decimal(12, 2)
  stockQuantity     Int?      @map("stock_quantity")
  currency          String?   @default("BRL")
  sku               String?
  categoryId        String?   @map("category_id")
  categoryName      String?   @map("category_name")
  attributes        Json?
  logistics         Json?
  status            String    @default("draft")
  externalListingId String?   @map("external_listing_id")
  externalUrl       String?   @map("external_url")
  errorMessage      String?   @map("error_message")
  publishedAt       DateTime? @map("published_at")
  lastSyncAt        DateTime? @map("last_sync_at")
  metadata          Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([platform])
  @@index([status])
  @@index([externalListingId])
  @@index([createdAt])
  @@map("marketplace_listings")
}

model SalesOrder {
  id              String    @id @default(cuid())
  customerName    String?   @map("customer_name")
  customerEmail   String?   @map("customer_email")
  platform        String?
  status          String    @default("paid")
  subtotal        Decimal   @default(0) @db.Decimal(12, 2)
  discount        Decimal   @default(0) @db.Decimal(12, 2)
  shipping        Decimal   @default(0) @db.Decimal(12, 2)
  total           Decimal   @default(0) @db.Decimal(12, 2)
  costTotal       Decimal   @default(0) @map("cost_total") @db.Decimal(12, 2)
  profit          Decimal   @default(0) @db.Decimal(12, 2)
  currency        String    @default("BRL")
  externalOrderId String?   @map("external_order_id")
  soldAt          DateTime  @default(now()) @map("sold_at")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  items SalesOrderItem[]

  @@index([platform])
  @@index([status])
  @@index([soldAt])
  @@index([externalOrderId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  productId   String?  @map("product_id")
  productName String   @map("product_name")
  sku         String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  unitCost    Decimal  @default(0) @map("unit_cost") @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  profit      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("sales_order_items")
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String?
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("BRL")
  spentAt     DateTime @default(now()) @map("spent_at")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([spentAt])
  @@map("expenses")
}

model Comment {
  id                String   @id @default(cuid())
  postId            String?  @map("post_id")
  externalCommentId String?  @map("external_comment_id")
  author            String?
  content           String?
  platform          String?
  isPurchaseIntent  Boolean  @default(false) @map("is_purchase_intent")
  autoReplied       Boolean  @default(false) @map("auto_replied")
  replyContent      String?  @map("reply_content")
  detectedAt        DateTime @default(now()) @map("detected_at")
  repliedAt         DateTime? @map("replied_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
  replies CommentReplyLog[]

  @@index([postId])
  @@index([platform])
  @@index([isPurchaseIntent])
  @@index([autoReplied])
  @@index([detectedAt])
  @@map("comments")
}

model CommentReplyLog {
  id        String   @id @default(cuid())
  commentId String   @map("comment_id")
  provider  String?
  status    String   @default("sent")
  content   String?
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_reply_logs")
}

model PlatformAccount {
  id           String   @id @default(cuid())
  platform     String   @unique
  accountName  String   @map("account_name")
  accountId    String?  @map("account_id")
  status       String   @default("disconnected")
  scopes       String[] @default([])
  accessToken  String?  @map("access_token")
  refreshToken String?  @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  lastSyncAt   DateTime? @map("last_sync_at")
  errorMessage String?  @map("error_message")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("platform_accounts")
}

model AutomationSetting {
  id               String   @id @default("automation_settings")
  autoReply        Boolean  @default(true) @map("auto_reply")
  autoSchedule     Boolean  @default(true) @map("auto_schedule")
  notifications    Boolean  @default(true)
  randomSchedule   Boolean  @default(true) @map("random_schedule")
  purchaseKeywords String[] @default(["eu quero", "quanto custa", "como comprar", "onde comprar", "link do produto"]) @map("purchase_keywords")
  postingStart     String   @default("08:00") @map("posting_start")
  postingEnd       String   @default("22:00") @map("posting_end")
  enabledPlatforms String[] @default(["instagram", "tiktok", "facebook", "youtube", "shopee", "mercadolivre"]) @map("enabled_platforms")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("automation_settings")
}

model Job {
  id           String   @id @default(cuid())
  type         String
  status       String   @default("queued")
  title        String
  progress     Int      @default(0)
  productId    String?  @map("product_id")
  mediaAssetId String?  @map("media_asset_id")
  postId       String?  @map("post_id")
  resultUrl    String?  @map("result_url")
  errorMessage String?  @map("error_message")
  payload      Json?
  result       Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  completedAt  DateTime? @map("completed_at")

  @@index([type])
  @@index([status])
  @@index([productId])
  @@index([mediaAssetId])
  @@index([postId])
  @@index([createdAt])
  @@map("jobs")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft")
  startAt     DateTime? @map("start_at")
  endAt       DateTime? @map("end_at")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("campaigns")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?  @map("actor_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
